" Generated from templates/vimrc.erb by atta-wm.

" Clipboard — route all yank/delete/put through the system clipboard
set clipboard=unnamedplus

" Sensible defaults
set nocompatible
set number
set relativenumber
set hlsearch
set incsearch
set ignorecase
set smartcase
set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent
set scrolloff=8
set signcolumn=yes
set wrap
set linebreak
set mouse=a
set encoding=utf-8
set backspace=indent,eol,start
set wildmenu
set wildmode=longest:full,full
set hidden
set noswapfile

syntax on
filetype plugin indent on
