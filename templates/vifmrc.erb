" Generated from templates/vifmrc.erb by atta-wm.

" Use vim as the editor
set vicmd=vim

" Clipboard integration — yank paths to system clipboard
" :yp copies the selected file's full path, :yd copies the directory path
command! yp :!echo %c:p | xclip -selection clipboard %i
command! yd :!echo %d | xclip -selection clipboard %i

" Sensible defaults
set trash
set history=100
set followlinks
set sortnumbers
set undolevels=100
set vimhelp
set norunexec
set timefmt='%Y-%m-%d %H:%M'
set wildmenu
set wildstyle=popup
set ignorecase
set smartcase
set nohlsearch
set incsearch
set scrolloff=4
set number

set statusline=" %t%= %A %10u:%-7g %15s %20d "

" Theme integration with atta-wm palette
highlight Win guifg=<%= theme_hex(:hlwm, :active_color) %> guibg=<%= theme_hex(:hlwm, :inactive_color) %>
highlight Directory gui=bold guifg=<%= theme_hex(:hlwm, :title_color) %> guibg=default
highlight Selected gui=reverse
highlight Border guifg=<%= theme_hex(:hlwm, :border_highlight) %> guibg=<%= theme_hex(:hlwm, :inactive_color) %>
highlight TopLine gui=bold guifg=<%= theme_hex(:hlwm, :border_highlight) %> guibg=<%= theme_hex(:hlwm, :inactive_color) %>
highlight StatusLine gui=bold guifg=<%= theme_hex(:hlwm, :active_color) %> guibg=<%= theme_hex(:hlwm, :inactive_color) %>
highlight CmdLine guifg=<%= theme_hex(:hlwm, :active_color) %> guibg=<%= theme_hex(:hlwm, :inactive_color) %>

" Marks
mark h ~/ Home
mark c ~/.config Config
mark d ~/Downloads Downloads

" File type associations
filetype {*.pdf},<application/pdf> xdg-open %f %i &
filetype {*.html,*.htm},<text/html> firefox %f %i &
filetype {*.png,*.jpg,*.jpeg,*.gif,*.bmp},<image/*> feh %f %i &

" Better previews with bat
fileviewer *.txt,*.md,*.json,*.yaml,*.yml,*.toml,*.ini,*.conf,*.sh,*.rb,*.py bat --color=always --style=plain --paging=never %c

" eza helpers
command! Tree :!eza --tree --level=3 --icons --group-directories-first --color=always %d | less -R
command! Ls :!eza -lah --icons --group-directories-first --git %d | less -R
nnoremap <leader>t :Tree<CR>
nnoremap <leader>l :Ls<CR>
