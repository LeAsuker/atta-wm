# Generated from templates/dunstrc.erb and configs/colors.yaml.

[global]
    monitor = 0
    follow = mouse

    width = 300
    height = 150
    origin = top-right
    offset = 12x48
    scale = 0
    gap_size = 4

    sort = yes

    font = Ubuntu Mono 10
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 0
    max_icon_size = 32

    frame_width = 2
    corner_radius = 0

    sticky_history = yes
    history_length = 20

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "<%= theme_hex(:dunst, :low_bg) %>"
    foreground = "<%= theme_hex(:dunst, :low_fg) %>"
    frame_color = "<%= theme_hex(:dunst, :low_frame) %>"
    timeout = 5

[urgency_normal]
    background = "<%= theme_hex(:dunst, :normal_bg) %>"
    foreground = "<%= theme_hex(:dunst, :normal_fg) %>"
    frame_color = "<%= theme_hex(:dunst, :normal_frame) %>"
    timeout = 10

[urgency_critical]
    background = "<%= theme_hex(:dunst, :critical_bg) %>"
    foreground = "<%= theme_hex(:dunst, :critical_fg) %>"
    frame_color = "<%= theme_hex(:dunst, :critical_frame) %>"
    timeout = 0
