# Generated from templates/kitty.conf.erb and configs/colors.yaml.

# Font
font_family      <%= theme_font(:kitty, :font, 'UbuntuMono', :nerd) %>
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        11
disable_ligatures never

# Terminal behavior
enable_audio_bell no
visual_bell_duration 0
window_alert_on_bell no
bell_on_tab no
cursor_shape block
cursor_blink_interval 0
shell_integration enabled
scrollback_lines 10000
scrollback_indicator_opacity 0.9
scrollbar scrolled
scrollbar_width 1
scrollbar_handle_opacity 0.6
scrollbar_handle_color <%= theme_hex(:kitty, :highlight) %>
scrollbar_track_color <%= theme_hex(:kitty, :bright_black) %>
mouse_hide_wait 2.0
wheel_scroll_multiplier 5.0
touch_scroll_multiplier 5.0
detect_urls yes
allow_hyperlinks yes
url_color <%= theme_hex(:kitty, :bright_cyan) %>
underline_hyperlinks always
open_url_with default
copy_on_select clipboard
show_hyperlink_targets yes
paste_actions quote-urls-at-prompt,confirm,confirm-if-large
strip_trailing_spaces smart
notify_on_cmd_finish invisible 10.0

# Window layout
tab_bar_style powerline
tab_powerline_style round
tab_bar_edge top
tab_bar_align left
tab_bar_margin_height 0 0
active_tab_font_style bold
inactive_tab_font_style normal
active_tab_background <%= theme_hex(:kitty, :highlight) %>
active_tab_foreground <%= theme_hex(:kitty, :background) %>
inactive_tab_background <%= theme_hex(:kitty, :bright_black) %>
inactive_tab_foreground <%= theme_hex(:kitty, :foreground) %>
active_border_color <%= theme_hex(:kitty, :highlight) %>
inactive_border_color <%= theme_hex(:kitty, :bright_black) %>
window_border_width 1pt
draw_minimal_borders yes
window_padding_width 8
placement_strategy center
hide_window_decorations no
resize_in_steps yes
confirm_os_window_close 1
remember_window_size yes
initial_window_width 110c
initial_window_height 32c
enabled_layouts splits,stack,tall,fat,grid
window_title_bar top
window_title_bar_min_windows 2
window_title_template {fmt.fg.tab}{title}
active_window_title_template {fmt.fg.red}{bell_symbol}{fmt.fg.tab}{title}

# Keybindings
map ctrl+shift+c copy_to_clipboard
map ctrl+shift+v paste_from_clipboard
map ctrl+shift+t new_tab_with_cwd
map ctrl+shift+enter launch --cwd=current
map ctrl+shift+] next_tab
map ctrl+shift+[ previous_tab
map ctrl+shift+equal change_font_size all +2.0
map ctrl+shift+minus change_font_size all -2.0
map ctrl+shift+0 change_font_size all 0
map ctrl+shift+u kitten hints --type=url --program default
map ctrl+shift+f kitten hints --type=path --program -
map ctrl+shift+h show_scrollback
map ctrl+shift+g show_last_command_output
map ctrl+shift+e open_url_with_hints
map ctrl+shift+/ search_scrollback

# Colors
background       <%= theme_hex(:kitty, :background) %>
foreground       <%= theme_hex(:kitty, :foreground) %>
cursor           <%= theme_hex(:kitty, :highlight) %>
cursor_text_color <%= theme_hex(:kitty, :background) %>
selection_foreground <%= theme_hex(:kitty, :background) %>
selection_background <%= theme_hex(:kitty, :highlight) %>
url_style single
tab_bar_background <%= theme_hex(:kitty, :background) %>
tab_title_template {index}: {title}
active_tab_title_template {fmt.fg.tab}{fmt.bold}{index}: {title}

# normal
color0  <%= theme_hex(:kitty, :black) %>
color1  <%= theme_hex(:kitty, :red) %>
color2  <%= theme_hex(:kitty, :green) %>
color3  <%= theme_hex(:kitty, :yellow) %>
color4  <%= theme_hex(:kitty, :blue) %>
color5  <%= theme_hex(:kitty, :magenta) %>
color6  <%= theme_hex(:kitty, :cyan) %>
color7  <%= theme_hex(:kitty, :white) %>

# bright
color8  <%= theme_hex(:kitty, :bright_black) %>
color9  <%= theme_hex(:kitty, :bright_red) %>
color10 <%= theme_hex(:kitty, :bright_green) %>
color11 <%= theme_hex(:kitty, :bright_yellow) %>
color12 <%= theme_hex(:kitty, :bright_blue) %>
color13 <%= theme_hex(:kitty, :bright_magenta) %>
color14 <%= theme_hex(:kitty, :bright_cyan) %>
color15 <%= theme_hex(:kitty, :bright_white) %>
